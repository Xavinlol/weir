{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(weir_requests_total, instance)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "bot_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(weir_requests_total, bot_id)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Reqs/s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Discord 429s (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "timeFrom": "1h",
      "targets": [
        {
          "expr": "sum(increase(weir_discord_429_total{instance=~\"$instance\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limited (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "timeFrom": "1h",
      "targets": [
        {
          "expr": "sum(increase(weir_rate_limited_total{instance=~\"$instance\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Buckets",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "weir_active_buckets{instance=~\"$instance\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Invalid Requests",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 10000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "orange", "value": 8000 },
              { "color": "red", "value": 9500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "weir_invalid_request_count{instance=~\"$instance\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cloudflare",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "BLOCKED", "color": "red" } } }
          ]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "weir_cloudflare_blocked{instance=~\"$instance\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval])) by (bot_id)",
          "legendFormat": "{{bot_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(weir_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(weir_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(weir_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Discord Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(weir_discord_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(weir_discord_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(weir_discord_latency_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_rate_limited_total{instance=~\"$instance\"}[$__rate_interval])) by (kind)",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Discord 429s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_discord_429_total{instance=~\"$instance\"}[$__rate_interval])) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Protection Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_protection_events_total{instance=~\"$instance\"}[$__rate_interval])) by (event)",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Discord Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_discord_errors_total{instance=~\"$instance\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Response Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(weir_requests_total{instance=~\"$instance\", bot_id=~\"$bot_id\"}[$__rate_interval])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["discord", "proxy", "weir"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Weir - Discord REST API Proxy",
  "uid": "weir-overview",
  "version": 2
}
